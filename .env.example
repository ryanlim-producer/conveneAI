# Required: AES-256-GCM encryption key (64 hex characters = 32 bytes)
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=

# Required: iron-session secret (at least 64 hex characters = 32 bytes)
# Generate: openssl rand -hex 32
SESSION_SECRET=

# Telegram bot token from @BotFather (optional — enables the Telegram surface)
TELEGRAM_BOT_TOKEN=

# Deepgram API key — server-wide fallback when no session key is set via the web UI
# Get yours at: https://console.deepgram.com
DEEPGRAM_API_KEY=

# Vercel AI Gateway key (for LLM features: action items + name detection)
# Get yours at: https://vercel.com/ai-gateway
VERCEL_AI_GATEWAY_KEY=

# Public base URL used in Telegram replies linking to the web UI
# (tunnel URL in dev, VPS URL in prod)
PUBLIC_BASE_URL=http://localhost:3000

# AWS S3 (audio storage) — IAM user needs Get/Put/DeleteObject on the bucket
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=
